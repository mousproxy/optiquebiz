  employees                                           employees[]
  frames                                              frames[]
  journal_entries_journal_entries_created_byTousers   journal_entries[]     @relation("journal_entries_created_byTousers")
  journal_entries_journal_entries_validated_byTousers journal_entries[]     @relation("journal_entries_validated_byTousers")
  leave_requests                                      leave_requests[]
  medical_history                                     medical_history[]
  notifications                                       notifications[]
  patients                                            patients[]
  payments                                            payments[]
  payroll                                             payroll[]
  prescriptions_prescriptions_created_byTousers       prescriptions[]       @relation("prescriptions_created_byTousers")
  prescriptions_prescriptions_doctor_idTousers        prescriptions[]       @relation("prescriptions_doctor_idTousers")
  purchase_orders_purchase_orders_created_byTousers   purchase_orders[]     @relation("purchase_orders_created_byTousers")
  purchase_orders_purchase_orders_validated_byTousers purchase_orders[]     @relation("purchase_orders_validated_byTousers")
  purchase_receptions                                 purchase_receptions[]
  quotes_quotes_created_byTousers                     quotes[]              @relation("quotes_created_byTousers")
  quotes_quotes_seller_idTousers                      quotes[]              @relation("quotes_seller_idTousers")
  sales_sales_cashier_idTousers                       sales[]               @relation("sales_cashier_idTousers")
  sales_sales_created_byTousers                       sales[]               @relation("sales_created_byTousers")
  sales_sales_seller_idTousers                        sales[]               @relation("sales_seller_idTousers")
  saved_reports                                       saved_reports[]
  stock_movements                                     stock_movements[]
  user_permissions                                    user_permissions[]
  companies                                           companies?            @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses                                          warehouses?           @relation(fields: [default_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
