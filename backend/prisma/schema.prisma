generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accessories {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String?     @db.Uuid
  warehouse_id   String?     @db.Uuid
  reference      String?     @db.VarChar(50)
  barcode        String?     @unique @db.VarChar(50)
  name           String      @db.VarChar(200)
  category       String?     @db.VarChar(100)
  brand_name     String?     @db.VarChar(100)
  unit           String?     @default("Pièce") @db.VarChar(20)
  purchase_price Decimal     @default(0) @db.Decimal(12, 2)
  sale_price     Decimal     @default(0) @db.Decimal(12, 2)
  tax_rate       Decimal?    @default(18.00) @db.Decimal(5, 2)
  stock_quantity Int?        @default(0)
  min_stock      Int?        @default(5)
  photo_url      String?
  is_active      Boolean?    @default(true)
  description    String?
  created_at     DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?   @default(now()) @db.Timestamptz(6)
  companies      companies?  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses     warehouses? @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model accounts {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String?               @db.Uuid
  code                String                @unique @db.VarChar(20)
  name                String                @db.VarChar(200)
  account_type        String?               @db.VarChar(50)
  account_class       String?               @db.VarChar(5)
  parent_id           String?               @db.Uuid
  is_detail           Boolean?              @default(true)
  current_balance     Decimal?              @default(0) @db.Decimal(12, 2)
  is_active           Boolean?              @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  companies           companies?            @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accounts            accounts?             @relation("accountsToaccounts", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_accounts      accounts[]            @relation("accountsToaccounts")
  journal_entry_lines journal_entry_lines[]
}

model appointments {
  id                                    String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                            String?             @db.Uuid
  patient_id                            String?             @db.Uuid
  doctor_id                             String?             @db.Uuid
  optician_id                           String?             @db.Uuid
  appointment_date                      DateTime            @db.Date
  start_time                            DateTime            @db.Time(6)
  end_time                              DateTime            @db.Time(6)
  duration                              Int?                @default(30)
  reason                                String?             @db.VarChar(200)
  room                                  String?             @db.VarChar(50)
  status                                appointment_status? @default(scheduled)
  notes                                 String?
  reminder_sent                         Boolean?            @default(false)
  reminder_sent_at                      DateTime?           @db.Timestamptz(6)
  confirmation_sent                     Boolean?            @default(false)
  is_first_visit                        Boolean?            @default(false)
  waiting_list_position                 Int?
  cancelled_reason                      String?
  rescheduled_from                      String?             @db.Uuid
  created_by                            String?             @db.Uuid
  created_at                            DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?           @default(now()) @db.Timestamptz(6)
  companies                             companies?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_created_byTousers  users?              @relation("appointments_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_doctor_idTousers   users?              @relation("appointments_doctor_idTousers", fields: [doctor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_optician_idTousers users?              @relation("appointments_optician_idTousers", fields: [optician_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                              patients?           @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments                          appointments?       @relation("appointmentsToappointments", fields: [rescheduled_from], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_appointments                    appointments[]      @relation("appointmentsToappointments")
  consultations                         consultations[]

  @@index([appointment_date], map: "idx_appointments_date")
  @@index([doctor_id], map: "idx_appointments_doctor")
  @@index([patient_id], map: "idx_appointments_patient")
  @@index([status], map: "idx_appointments_status")
}

model attendance {
  id              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employee_id     String?    @db.Uuid
  attendance_date DateTime   @db.Date
  check_in        DateTime?  @db.Time(6)
  check_out       DateTime?  @db.Time(6)
  worked_hours    Decimal?   @db.Decimal(4, 2)
  status          String?    @default("present") @db.VarChar(20)
  overtime_hours  Decimal?   @default(0) @db.Decimal(4, 2)
  notes           String?
  recorded_by     String?    @db.Uuid
  created_at      DateTime?  @default(now()) @db.Timestamptz(6)
  employees       employees? @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?     @relation(fields: [recorded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([employee_id, attendance_date])
}

model audit_logs {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String?    @db.Uuid
  user_id     String?    @db.Uuid
  user_name   String?    @db.VarChar(200)
  action      String     @db.VarChar(100)
  resource    String?    @db.VarChar(100)
  resource_id String?    @db.Uuid
  description String?
  old_data    Json?
  new_data    Json?
  ip_address  String?    @db.VarChar(45)
  user_agent  String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  companies   companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([action], map: "idx_audit_logs_action")
  @@index([created_at], map: "idx_audit_logs_date")
  @@index([resource, resource_id], map: "idx_audit_logs_resource")
  @@index([user_id], map: "idx_audit_logs_user")
}

model bank_accounts {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id        String?             @db.Uuid
  bank_name         String              @db.VarChar(100)
  account_name      String?             @db.VarChar(100)
  account_number    String              @db.VarChar(50)
  iban              String?             @db.VarChar(50)
  swift             String?             @db.VarChar(20)
  current_balance   Decimal?            @default(0) @db.Decimal(12, 2)
  is_default        Boolean?            @default(false)
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  companies         companies?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bank_transactions bank_transactions[]
}

model bank_transactions {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bank_account_id  String?        @db.Uuid
  transaction_date DateTime       @db.Date
  value_date       DateTime?      @db.Date
  description      String?        @db.VarChar(300)
  debit            Decimal?       @default(0) @db.Decimal(12, 2)
  credit           Decimal?       @default(0) @db.Decimal(12, 2)
  balance          Decimal?       @db.Decimal(12, 2)
  reference        String?        @db.VarChar(100)
  is_reconciled    Boolean?       @default(false)
  created_at       DateTime?      @default(now()) @db.Timestamptz(6)
  bank_accounts    bank_accounts? @relation(fields: [bank_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model brands {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String?          @db.Uuid
  name           String           @unique @db.VarChar(100)
  category       String?          @db.VarChar(50)
  country        String?          @db.VarChar(50)
  logo_url       String?
  website        String?          @db.VarChar(200)
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  companies      companies?       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact_lenses contact_lenses[]
  frames         frames[]
  lenses         lenses[]
}

model campaign_recipients {
  id                String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  campaign_id       String?    @db.Uuid
  patient_id        String?    @db.Uuid
  recipient_name    String?    @db.VarChar(200)
  recipient_contact String?    @db.VarChar(200)
  status            String?    @default("pending") @db.VarChar(20)
  sent_at           DateTime?  @db.Timestamptz(6)
  delivered_at      DateTime?  @db.Timestamptz(6)
  opened_at         DateTime?  @db.Timestamptz(6)
  error_message     String?
  created_at        DateTime?  @default(now()) @db.Timestamptz(6)
  campaigns         campaigns? @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patients          patients?  @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model campaigns {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String?               @db.Uuid
  name                String                @db.VarChar(200)
  campaign_type       campaign_type
  subject             String?               @db.VarChar(300)
  content             String
  target_segment      Json?                 @default("{}")
  target_count        Int?                  @default(0)
  sent_count          Int?                  @default(0)
  delivered_count     Int?                  @default(0)
  opened_count        Int?                  @default(0)
  status              campaign_status?      @default(draft)
  scheduled_at        DateTime?             @db.Timestamptz(6)
  sent_at             DateTime?             @db.Timestamptz(6)
  created_by          String?               @db.Uuid
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  campaign_recipients campaign_recipients[]
  companies           companies?            @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?                @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model cash_movements {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  session_id     String?            @db.Uuid
  register_id    String?            @db.Uuid
  movement_type  cash_movement_type
  amount         Decimal            @db.Decimal(12, 2)
  balance_after  Decimal?           @db.Decimal(12, 2)
  reference      String?            @db.VarChar(100)
  description    String?            @db.VarChar(300)
  payment_id     String?            @db.Uuid
  created_by     String?            @db.Uuid
  created_at     DateTime?          @default(now()) @db.Timestamptz(6)
  users          users?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       payments?          @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cash_registers cash_registers?    @relation(fields: [register_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cash_sessions  cash_sessions?     @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model cash_registers {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String?          @db.Uuid
  warehouse_id    String?          @db.Uuid
  code            String           @unique @db.VarChar(20)
  name            String           @db.VarChar(100)
  location        String?          @db.VarChar(100)
  current_balance Decimal?         @default(0) @db.Decimal(12, 2)
  is_open         Boolean?         @default(false)
  is_active       Boolean?         @default(true)
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  cash_movements  cash_movements[]
  companies       companies?       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses      warehouses?      @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cash_sessions   cash_sessions[]
}

model cash_sessions {
  id                                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  register_id                          String?          @db.Uuid
  session_number                       String           @unique @db.VarChar(30)
  opening_amount                       Decimal          @default(0) @db.Decimal(12, 2)
  closing_amount                       Decimal?         @db.Decimal(12, 2)
  expected_amount                      Decimal?         @db.Decimal(12, 2)
  difference                           Decimal?         @db.Decimal(12, 2)
  opened_by                            String?          @db.Uuid
  closed_by                            String?          @db.Uuid
  opened_at                            DateTime         @default(now()) @db.Timestamptz(6)
  closed_at                            DateTime?        @db.Timestamptz(6)
  notes                                String?
  is_open                              Boolean?         @default(true)
  cash_movements                       cash_movements[]
  users_cash_sessions_closed_byTousers users?           @relation("cash_sessions_closed_byTousers", fields: [closed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_cash_sessions_opened_byTousers users?           @relation("cash_sessions_opened_byTousers", fields: [opened_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cash_registers                       cash_registers?  @relation(fields: [register_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model companies {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String                @db.VarChar(200)
  legal_name          String?               @db.VarChar(200)
  tax_number          String?               @db.VarChar(50)
  rccm                String?               @db.VarChar(50)
  address             String?
  city                String?               @default("Abidjan") @db.VarChar(100)
  country             String?               @default("Côte d'Ivoire") @db.VarChar(100)
  phone               String?               @db.VarChar(20)
  phone2              String?               @db.VarChar(20)
  email               String?               @db.VarChar(150)
  website             String?               @db.VarChar(200)
  logo_url            String?
  currency            String?               @default("FCFA") @db.VarChar(10)
  currency_symbol     String?               @default("F") @db.VarChar(5)
  tax_rate            Decimal?              @default(18.00) @db.Decimal(5, 2)
  invoice_prefix      String?               @default("FAC") @db.VarChar(10)
  quote_prefix        String?               @default("DEV") @db.VarChar(10)
  po_prefix           String?               @default("CMD") @db.VarChar(10)
  patient_prefix      String?               @default("PAT") @db.VarChar(10)
  footer_text         String?
  is_active           Boolean?              @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  accessories         accessories[]
  accounts            accounts[]
  appointments        appointments[]
  audit_logs          audit_logs[]
  bank_accounts       bank_accounts[]
  brands              brands[]
  campaigns           campaigns[]
  cash_registers      cash_registers[]
  consultations       consultations[]
  contact_lenses      contact_lenses[]
  credit_notes        credit_notes[]
  customers           customers[]
  documents           documents[]
  employees           employees[]
  frames              frames[]
  journal_entries     journal_entries[]
  lenses              lenses[]
  notifications       notifications[]
  patients            patients[]
  payments            payments[]
  prescriptions       prescriptions[]
  purchase_orders     purchase_orders[]
  purchase_receptions purchase_receptions[]
  quotes              quotes[]
  sales               sales[]
  saved_reports       saved_reports[]
  sequences           sequences[]
  services            services[]
  stock_movements     stock_movements[]
  suppliers           suppliers[]
  users               users[]
  warehouses          warehouses[]
  subscriptions       subscriptions?
}

model plans {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key            String          @unique @db.VarChar(30)
  name           String          @db.VarChar(100)
  price          Decimal         @default(0) @db.Decimal(12, 2)
  currency       String?         @default("FCFA") @db.VarChar(10)
  billing_period String?         @default("monthly") @db.VarChar(20)
  modules        String[]
  is_active      Boolean?        @default(true)
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  subscriptions  subscriptions[]
}

model subscriptions {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id         String    @unique @db.Uuid
  plan_id            String    @db.Uuid
  status             String    @default("trialing") @db.VarChar(20)
  trial_ends_at      DateTime? @db.Timestamptz(6)
  current_period_end DateTime? @db.Timestamptz(6)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  companies          companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  plans              plans     @relation(fields: [plan_id], references: [id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model consultations {
  id                                    String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                            String?         @db.Uuid
  patient_id                            String?         @db.Uuid
  doctor_id                             String?         @db.Uuid
  appointment_id                        String?         @db.Uuid
  consultation_date                     DateTime        @default(dbgenerated("CURRENT_DATE")) @db.Date
  va_od_sc                              String?         @db.VarChar(10)
  va_od_cc                              String?         @db.VarChar(10)
  va_og_sc                              String?         @db.VarChar(10)
  va_og_cc                              String?         @db.VarChar(10)
  od_sph                                Decimal?        @db.Decimal(5, 2)
  od_cyl                                Decimal?        @db.Decimal(5, 2)
  od_axe                                Int?
  od_add                                Decimal?        @db.Decimal(4, 2)
  od_prism                              Decimal?        @db.Decimal(4, 2)
  od_prism_base                         String?         @db.VarChar(10)
  og_sph                                Decimal?        @db.Decimal(5, 2)
  og_cyl                                Decimal?        @db.Decimal(5, 2)
  og_axe                                Int?
  og_add                                Decimal?        @db.Decimal(4, 2)
  og_prism                              Decimal?        @db.Decimal(4, 2)
  og_prism_base                         String?         @db.VarChar(10)
  np_od_sph                             Decimal?        @db.Decimal(5, 2)
  np_og_sph                             Decimal?        @db.Decimal(5, 2)
  iop_od                                Decimal?        @db.Decimal(5, 1)
  iop_og                                Decimal?        @db.Decimal(5, 1)
  fundus_od                             String?
  fundus_og                             String?
  keratometry_od                        String?         @db.VarChar(100)
  keratometry_og                        String?         @db.VarChar(100)
  diagnosis                             String?
  treatment                             String?
  next_appointment                      DateTime?       @db.Date
  comments                              String?
  signature_url                         String?
  is_printed                            Boolean?        @default(false)
  created_by                            String?         @db.Uuid
  created_at                            DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?       @default(now()) @db.Timestamptz(6)
  appointments                          appointments?   @relation(fields: [appointment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies                             companies?      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_consultations_created_byTousers users?          @relation("consultations_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_consultations_doctor_idTousers  users?          @relation("consultations_doctor_idTousers", fields: [doctor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                              patients?       @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescriptions                         prescriptions[]

  @@index([consultation_date], map: "idx_consultations_date")
  @@index([doctor_id], map: "idx_consultations_doctor")
  @@index([patient_id], map: "idx_consultations_patient")
}

model contact_lenses {
  id                    String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id            String?     @db.Uuid
  brand_id              String?     @db.Uuid
  warehouse_id          String?     @db.Uuid
  reference             String      @db.VarChar(50)
  barcode               String?     @unique @db.VarChar(50)
  name                  String      @db.VarChar(200)
  lens_subtype          String?     @db.VarChar(50)
  replacement_frequency String?     @db.VarChar(50)
  correction_type       String?     @db.VarChar(50)
  sphere                Decimal?    @db.Decimal(5, 2)
  cylinder              Decimal?    @db.Decimal(5, 2)
  axis                  Int?
  addition              Decimal?    @db.Decimal(4, 2)
  base_curve            Decimal?    @db.Decimal(4, 2)
  diameter              Decimal?    @db.Decimal(4, 1)
  water_content         Decimal?    @db.Decimal(4, 1)
  material              String?     @db.VarChar(100)
  purchase_price        Decimal     @default(0) @db.Decimal(12, 2)
  sale_price            Decimal     @default(0) @db.Decimal(12, 2)
  stock_quantity        Int?        @default(0)
  min_stock             Int?        @default(10)
  is_active             Boolean?    @default(true)
  created_at            DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?   @default(now()) @db.Timestamptz(6)
  brands                brands?     @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies             companies?  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses            warehouses? @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model credit_notes {
  id               String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String?    @db.Uuid
  reference        String     @unique @db.VarChar(30)
  patient_id       String?    @db.Uuid
  related_sale_id  String?    @db.Uuid
  amount           Decimal    @db.Decimal(12, 2)
  remaining_amount Decimal    @db.Decimal(12, 2)
  reason           String?
  status           String?    @default("active") @db.VarChar(20)
  created_by       String?    @db.Uuid
  created_at       DateTime?  @default(now()) @db.Timestamptz(6)
  companies        companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients         patients?  @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales            sales?     @relation(fields: [related_sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model customers {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String?    @db.Uuid
  code          String     @unique @db.VarChar(30)
  customer_type String?    @default("individual") @db.VarChar(20)
  company_name  String?    @db.VarChar(200)
  first_name    String?    @db.VarChar(100)
  last_name     String?    @db.VarChar(100)
