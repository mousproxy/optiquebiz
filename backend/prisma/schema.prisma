  reception_id         String?               @db.Uuid
  order_item_id        String?               @db.Uuid
  product_type         product_category
  product_id           String                @db.Uuid
  quantity_received    Int
  unit_cost            Decimal               @db.Decimal(12, 2)
  lot_number           String?               @db.VarChar(50)
  expiry_date          DateTime?             @db.Date
  notes                String?
  created_at           DateTime?             @default(now()) @db.Timestamptz(6)
  purchase_order_items purchase_order_items? @relation(fields: [order_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_receptions  purchase_receptions?  @relation(fields: [reception_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model purchase_receptions {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id               String?                    @db.Uuid
  reference                String                     @unique @db.VarChar(30)
  order_id                 String?                    @db.Uuid
  supplier_id              String?                    @db.Uuid
  reception_date           DateTime                   @default(dbgenerated("CURRENT_DATE")) @db.Date
  invoice_number           String?                    @db.VarChar(50)
  invoice_date             DateTime?                  @db.Date
  notes                    String?
  created_by               String?                    @db.Uuid
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  purchase_reception_items purchase_reception_items[]
  companies                companies?                 @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                    users?                     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_orders          purchase_orders?           @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers                suppliers?                 @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model quote_items {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  quote_id         String?          @db.Uuid
  line_number      Int
  product_type     product_category
  product_id       String?          @db.Uuid
  product_name     String           @db.VarChar(200)
  product_ref      String?          @db.VarChar(100)
  quantity         Int              @default(1)
  unit_price       Decimal          @db.Decimal(12, 2)
  discount_percent Decimal?         @default(0) @db.Decimal(5, 2)
  total_price      Decimal          @db.Decimal(12, 2)
  notes            String?
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  quotes           quotes?          @relation(fields: [quote_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model quotes {
  id                             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                     String?        @db.Uuid
  reference                      String         @unique @db.VarChar(30)
  patient_id                     String?        @db.Uuid
  prescription_id                String?        @db.Uuid
  seller_id                      String?        @db.Uuid
  quote_date                     DateTime       @default(dbgenerated("CURRENT_DATE")) @db.Date
  valid_until                    DateTime?      @db.Date
  subtotal                       Decimal?       @default(0) @db.Decimal(12, 2)
  discount_amount                Decimal?       @default(0) @db.Decimal(12, 2)
  tax_amount                     Decimal?       @default(0) @db.Decimal(12, 2)
  total_amount                   Decimal?       @default(0) @db.Decimal(12, 2)
  status                         String?        @default("draft") @db.VarChar(20)
  notes                          String?
  converted_to_sale_id           String?        @db.Uuid
  created_by                     String?        @db.Uuid
  created_at                     DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime?      @default(now()) @db.Timestamptz(6)
  quote_items                    quote_items[]
  companies                      companies?     @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales                          sales?         @relation(fields: [converted_to_sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_quotes_created_byTousers users?         @relation("quotes_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                       patients?      @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescriptions                  prescriptions? @relation(fields: [prescription_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_quotes_seller_idTousers  users?         @relation("quotes_seller_idTousers", fields: [seller_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model role_permissions {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  role          user_role
  permission_id String?      @db.Uuid
  permissions   permissions? @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([role, permission_id])
}

model sale_items {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sale_id          String?          @db.Uuid
  line_number      Int
  product_type     product_category
  product_id       String           @db.Uuid
  product_name     String           @db.VarChar(200)
  product_ref      String?          @db.VarChar(100)
  eye              String?          @db.VarChar(5)
  quantity         Int              @default(1)
  unit_price       Decimal          @db.Decimal(12, 2)
  discount_percent Decimal?         @default(0) @db.Decimal(5, 2)
  discount_amount  Decimal?         @default(0) @db.Decimal(12, 2)
  tax_rate         Decimal?         @default(18.00) @db.Decimal(5, 2)
  tax_amount       Decimal?         @default(0) @db.Decimal(12, 2)
  total_price      Decimal          @db.Decimal(12, 2)
  notes            String?
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  sales            sales?           @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sale_id], map: "idx_sale_items_sale")
}

model sales {
  id                            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                    String?        @db.Uuid
  warehouse_id                  String?        @db.Uuid
  reference                     String         @unique @db.VarChar(30)
  sale_type                     String?        @default("sale") @db.VarChar(20)
  patient_id                    String?        @db.Uuid
  customer_id                   String?        @db.Uuid
  prescription_id               String?        @db.Uuid
  seller_id                     String?        @db.Uuid
  cashier_id                    String?        @db.Uuid
  sale_date                     DateTime       @default(dbgenerated("CURRENT_DATE")) @db.Date
  sale_time                     DateTime?      @default(dbgenerated("CURRENT_TIME")) @db.Time(6)
  subtotal                      Decimal        @default(0) @db.Decimal(12, 2)
  discount_percent              Decimal?       @default(0) @db.Decimal(5, 2)
  discount_amount               Decimal?       @default(0) @db.Decimal(12, 2)
  tax_rate                      Decimal?       @default(18.00) @db.Decimal(5, 2)
  tax_amount                    Decimal?       @default(0) @db.Decimal(12, 2)
  total_amount                  Decimal        @default(0) @db.Decimal(12, 2)
  paid_amount                   Decimal?       @default(0) @db.Decimal(12, 2)
  remaining_amount              Decimal?       @default(0) @db.Decimal(12, 2)
  status                        sale_status?   @default(pending)
  is_ready                      Boolean?       @default(false)
  ready_date                    DateTime?      @db.Date
  notes                         String?
  internal_notes                String?
  related_sale_id               String?        @db.Uuid
  created_by                    String?        @db.Uuid
  created_at                    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime?      @default(now()) @db.Timestamptz(6)
  credit_notes                  credit_notes[]
  payments                      payments[]
  quotes                        quotes[]
  sale_items                    sale_items[]
  users_sales_cashier_idTousers users?         @relation("sales_cashier_idTousers", fields: [cashier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies                     companies?     @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_sales_created_byTousers users?         @relation("sales_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers                     customers?     @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                      patients?      @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescriptions                 prescriptions? @relation(fields: [prescription_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales                         sales?         @relation("salesTosales", fields: [related_sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_sales                   sales[]        @relation("salesTosales")
  users_sales_seller_idTousers  users?         @relation("sales_seller_idTousers", fields: [seller_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses                    warehouses?    @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([sale_date], map: "idx_sales_date")
  @@index([patient_id], map: "idx_sales_patient")
  @@index([reference], map: "idx_sales_reference")
  @@index([status], map: "idx_sales_status")
}

model saved_reports {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String?    @db.Uuid
  name          String     @db.VarChar(200)
  report_type   String     @db.VarChar(100)
  filters       Json?      @default("{}")
  columns       Json?      @default("[]")
  chart_config  Json?      @default("{}")
  is_scheduled  Boolean?   @default(false)
  schedule_cron String?    @db.VarChar(50)
  last_run      DateTime?  @db.Timestamptz(6)
  created_by    String?    @db.Uuid
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  companies     companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sequences {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String?    @db.Uuid
  sequence_type String     @db.VarChar(50)
  prefix        String?    @default("") @db.VarChar(20)
  suffix        String?    @default("") @db.VarChar(20)
  next_value    Int?       @default(1)
  padding       Int?       @default(6)
  format        String?    @default("{PREFIX}{NUM}") @db.VarChar(50)
  reset_period  String?    @db.VarChar(20)
  last_reset    DateTime?  @db.Date
  companies     companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([company_id, sequence_type])
}

model services {
  id               String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String?    @db.Uuid
  code             String?    @unique @db.VarChar(20)
  name             String     @db.VarChar(200)
  category         String?    @db.VarChar(100)
  unit_price       Decimal    @default(0) @db.Decimal(12, 2)
  tax_rate         Decimal?   @default(18.00) @db.Decimal(5, 2)
  duration_minutes Int?       @default(30)
  is_active        Boolean?   @default(true)
  description      String?
  created_at       DateTime?  @default(now()) @db.Timestamptz(6)
  companies        companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model stock_movements {
  id                                                       String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                                               String?          @db.Uuid
  warehouse_id                                             String?          @db.Uuid
  warehouse_dest_id                                        String?          @db.Uuid
  product_type                                             product_category
  product_id                                               String           @db.Uuid
  movement_type                                            movement_type
  quantity                                                 Int
  unit_cost                                                Decimal?         @db.Decimal(12, 2)
  total_cost                                               Decimal?         @db.Decimal(12, 2)
  reference                                                String?          @db.VarChar(100)
  lot_number                                               String?          @db.VarChar(50)
  expiry_date                                              DateTime?        @db.Date
  reason                                                   String?
  notes                                                    String?
  related_sale_id                                          String?          @db.Uuid
  related_purchase_id                                      String?          @db.Uuid
  created_by                                               String?          @db.Uuid
  created_at                                               DateTime?        @default(now()) @db.Timestamptz(6)
  companies                                                companies?       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                    users?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses_stock_movements_warehouse_dest_idTowarehouses warehouses?      @relation("stock_movements_warehouse_dest_idTowarehouses", fields: [warehouse_dest_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses_stock_movements_warehouse_idTowarehouses      warehouses?      @relation("stock_movements_warehouse_idTowarehouses", fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_stock_movements_date")
  @@index([product_type, product_id], map: "idx_stock_movements_product")
  @@index([movement_type], map: "idx_stock_movements_type")
}

model suppliers {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String?               @db.Uuid
  code                String                @unique @db.VarChar(30)
  name                String                @db.VarChar(200)
  contact_name        String?               @db.VarChar(100)
  phone               String?               @db.VarChar(20)
  phone2              String?               @db.VarChar(20)
  email               String?               @db.VarChar(150)
  address             String?
  city                String?               @db.VarChar(100)
  country             String?               @default("Côte d'Ivoire") @db.VarChar(100)
  tax_number          String?               @db.VarChar(50)
  rccm                String?               @db.VarChar(50)
