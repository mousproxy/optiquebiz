# Application
NODE_ENV=development
PORT=5000
APP_NAME=OptiGest
APP_URL=http://localhost:5000

# Base de données PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/optigest_db"

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise_ici_changez_moi
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=votre_refresh_secret_jwt_tres_securise
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Fichiers uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM=noreply@optigest.ci
EMAIL_FROM_NAME=OptiGest

# SMS (Africa's Talking ou autre)
SMS_API_KEY=votre_cle_api_sms
SMS_API_URL=https://api.africastalking.com/version1/messaging
SMS_SENDER=OptiGest

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_DIR=./logs

# Backup
BACKUP_DIR=./backups
BACKUP_CRON=0 2 * * *
